# ============================================================
# StreamFinder v3 — Complete Security & Environment Config
# Copy this to .env.local and fill in your values
# ============================================================

# ── TMDb API (required) ────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here

# ── Database (required for auth + profiles + reviews) ──────
# Free tier options:
#   Supabase: https://supabase.com (PostgreSQL)
#   PlanetScale: https://planetscale.com (MySQL)
#   Railway: https://railway.app
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── NextAuth (required for authentication) ────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_32_char_secret_here
NEXTAUTH_URL=http://localhost:3000

# ── OAuth Providers (optional) ────────────────────────────
# Get from: https://console.cloud.google.com/ (Google)
#           https://github.com/settings/developers (GitHub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Site Configuration ────────────────────────────────────
NEXT_PUBLIC_DEFAULT_COUNTRY=US
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=StreamFinder

# ── Affiliate Links ───────────────────────────────────────
# Get from: https://affiliate-program.amazon.com/
#           https://performance-partners.apple.com/
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=yourtag-20
NEXT_PUBLIC_APPLE_AFFILIATE_TOKEN=your_apple_token

# ── Google AdSense (optional for monetization) ────────────
# Get from: https://adsense.google.com/
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-0000000000000000
NEXT_PUBLIC_AD_SLOT_HEADER=0000000000
NEXT_PUBLIC_AD_SLOT_SIDEBAR=1111111111
NEXT_PUBLIC_AD_SLOT_BELOW_PROVIDERS=2222222222

# ── Stripe (USD payments) ─────────────────────────────────
# Dashboard: https://dashboard.stripe.com/
# Get API keys from: Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CRITIC_PRICE_ID=price_...
STRIPE_CREATOR_PRICE_ID=price_...
STRIPE_STUDIO_PRICE_ID=price_...

# ── Razorpay (INR payments) ───────────────────────────────
# Dashboard: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
RAZORPAY_CRITIC_PLAN_ID=plan_...
RAZORPAY_CREATOR_PLAN_ID=plan_...
RAZORPAY_STUDIO_PLAN_ID=plan_...

# ============================================================
# SECURITY: Rate Limiting & CAPTCHA (Required in production)
# ============================================================

# ── Upstash Redis (for rate limiting) ──────────────────────
# Free tier: https://upstash.com/ (10k requests/day)
# Create a Redis database in the console and copy these URLs
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── CAPTCHA Provider (choose ONE) ──────────────────────────
# Option 1: hCaptcha (privacy-first, free)
#   Website: https://www.hcaptcha.com/
#   Sign up → Websites → Create account → Get your keys
CAPTCHA_PROVIDER=hcaptcha
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key

# Option 2: Cloudflare Turnstile (completely free, invisible)
#   Website: https://www.cloudflare.com/products/turnstile/
#   Dashboard → Account → Turnstile → Add site → Get keys
# Uncomment to use Turnstile instead of hCaptcha:
# CAPTCHA_PROVIDER=turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
# TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ============================================================
# OPTIONAL: Advanced Security Settings
# ============================================================

# IP Allowlist/Blocklist (for advanced deployments)
# Leave empty to allow all IPs (default)
ALLOWED_IPS=
BLOCKED_IPS=

# Bot Detection Strictness
# 'permissive' = warn but allow bots
# 'strict' = block bots with score > 0.6
BOT_DETECTION_MODE=permissive

# Rate Limit Presets (adjust for your traffic)
# Format: RATE_LIMIT_LOGIN=5@15m (5 requests per 15 minutes)
RATE_LIMIT_LOGIN=5@15m
RATE_LIMIT_REGISTER=3@1h
RATE_LIMIT_SEARCH=30@1m
RATE_LIMIT_CHECKOUT=5@1h

# ============================================================
# Development vs Production
# ============================================================
NODE_ENV=production
NEXTAUTH_DEBUG=false
ENABLE_VERBOSE_LOGGING=false
